# ============================================================
# Surf App 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
#   cp .env.example .env.local
# ============================================================

# --- Sentry（エラー監視）---
# https://sentry.io でプロジェクトを作成後、DSN を取得してください
# 未設定の場合は Sentry が無効になります（ローカル開発では空のままで OK）
SENTRY_DSN=

# --- アプリ URL ---
# デプロイ先の URL を設定してください
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase（認証・ユーザー管理）---
# https://supabase.com でプロジェクトを作成後、Settings → API から取得してください
#   NEXT_PUBLIC_SUPABASE_URL      = Project URL（https://xxxxx.supabase.co）
#   NEXT_PUBLIC_SUPABASE_ANON_KEY = anon public キー（eyJ... で始まる公開用キー）
# ※ service_role キーは秘密。クライアントに露出する NEXT_PUBLIC_ には絶対に入れないこと。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
